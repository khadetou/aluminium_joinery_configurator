<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_aluminium_joinery" model="ir.module.category">
            <field name="name">Configurateur menuiserie aluminium</field>
            <field name="description">Gérer les droits d'accès du configurateur de menuiserie aluminium.</field>
            <field name="sequence">25</field>
        </record>

        <record id="res_groups_privilege_aluminium_joinery" model="res.groups.privilege">
            <field name="name">Menuiserie aluminium</field>
            <field name="category_id" ref="aluminium_joinery_configurator.module_category_aluminium_joinery"/>
            <field name="sequence">25</field>
        </record>

        <record id="group_aluminium_joinery_user" model="res.groups">
            <field name="name">Utilisateur</field>
            <field name="privilege_id" ref="aluminium_joinery_configurator.res_groups_privilege_aluminium_joinery"/>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_aluminium_joinery_manager" model="res.groups">
            <field name="name">Responsable</field>
            <field name="privilege_id" ref="aluminium_joinery_configurator.res_groups_privilege_aluminium_joinery"/>
            <field name="sequence">20</field>
            <field name="implied_ids" eval="[(4, ref('aluminium_joinery_configurator.group_aluminium_joinery_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aluminium_joinery_gamme_tree" model="ir.ui.view">
        <field name="name">aluminium.joinery.gamme.tree</field>
        <field name="model">aluminium.joinery.gamme</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="default_bar_length_mm"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_aluminium_joinery_gamme_form" model="ir.ui.view">
        <field name="name">aluminium.joinery.gamme.form</field>
        <field name="model">aluminium.joinery.gamme</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="default_bar_length_mm"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Series">
                            <field name="serie_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aluminium_joinery_gamme" model="ir.actions.act_window">
        <field name="name">Gammes</field>
        <field name="res_model">aluminium.joinery.gamme</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aluminium_joinery_gamme_import" model="ir.actions.act_window">
        <field name="name">Importer les gammes</field>
        <field name="res_model">aluminium.joinery.gamme</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Utilisez le menu d'action pour importer vos gammes.</p>
            <p>Dans l'ecran d'import natif, vous trouverez les liens pour telecharger un modele minimal et un exemplaire issu du VBA.</p>
        </field>
    </record>

    <record id="view_aluminium_joinery_serie_tree" model="ir.ui.view">
        <field name="name">aluminium.joinery.serie.tree</field>
        <field name="model">aluminium.joinery.serie</field>
        <field name="arch" type="xml">
            <list>
                <field name="gamme_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="opening_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_aluminium_joinery_serie_form" model="ir.ui.view">
        <field name="name">aluminium.joinery.serie.form</field>
        <field name="model">aluminium.joinery.serie</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="gamme_id"/>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="opening_type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Modeles">
                            <field name="modele_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aluminium_joinery_serie" model="ir.actions.act_window">
        <field name="name">Series</field>
        <field name="res_model">aluminium.joinery.serie</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aluminium_joinery_serie_import" model="ir.actions.act_window">
        <field name="name">Importer les series</field>
        <field name="res_model">aluminium.joinery.serie</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Utilisez le menu d'action pour importer vos series.</p>
            <p>Dans l'ecran d'import natif, les fichiers d'exemple et les modeles sont proposes automatiquement.</p>
        </field>
    </record>

    <record id="view_aluminium_joinery_modele_tree" model="ir.ui.view">
        <field name="name">aluminium.joinery.modele.tree</field>
        <field name="model">aluminium.joinery.modele</field>
        <field name="arch" type="xml">
            <list>
                <field name="gamme_id"/>
                <field name="serie_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="panel_count"/>
                <field name="rail_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_aluminium_joinery_modele_form" model="ir.ui.view">
        <field name="name">aluminium.joinery.modele.form</field>
        <field name="model">aluminium.joinery.modele</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="gamme_id" readonly="1"/>
                            <field name="serie_id"/>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="panel_count"/>
                            <field name="rail_count"/>
                            <field name="x_import_key"/>
                            <field name="sale_product_tmpl_id"/>
                            <field name="manufactured_product_tmpl_id"/>
                            <field name="project_template_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Regles">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="product_id"/>
                                    <field name="product_default_code"/>
                                    <field name="formula_family"/>
                                    <field name="target_measure"/>
                                    <field name="multiplier"/>
                                </list>
                            </field>
                        </page>
                        <page string="Remplissage">
                            <field name="filling_rule_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="product_default_code"/>
                                    <field name="family_width"/>
                                    <field name="family_height"/>
                                    <field name="family_qty"/>
                                    <field name="product_is_placeholder" readonly="1"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aluminium_joinery_modele" model="ir.actions.act_window">
        <field name="name">Modeles</field>
        <field name="res_model">aluminium.joinery.modele</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aluminium_joinery_modele_import" model="ir.actions.act_window">
        <field name="name">Importer les modeles</field>
        <field name="res_model">aluminium.joinery.modele</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Utilisez le menu d'action pour importer vos modeles.</p>
            <p>Le panneau d'aide de l'import natif propose le modele minimal et l'exemplaire complet du catalogue VBA.</p>
        </field>
    </record>

    <record id="view_aluminium_joinery_rule_tree" model="ir.ui.view">
        <field name="name">aluminium.joinery.rule.tree</field>
        <field name="model">aluminium.joinery.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="modele_id"/>
                <field name="sequence"/>
                <field name="name"/>
                <field name="category"/>
                <field name="product_id"/>
                <field name="formula_family"/>
                <field name="target_measure"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_aluminium_joinery_rule_form" model="ir.ui.view">
        <field name="name">aluminium.joinery.rule.form</field>
        <field name="model">aluminium.joinery.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="modele_id"/>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="category"/>
                            <field name="product_id"/>
                            <field name="product_default_code"/>
                            <field name="ref_text"/>
                            <field name="designation_override"/>
                            <field name="rule_code"/>
                            <field name="profile_role"/>
                            <field name="cut_type"/>
                            <field name="product_resolution_mode"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="formula_family"/>
                            <field name="target_measure"/>
                            <field name="multiplier"/>
                            <field name="coef_l"/>
                            <field name="offset_l"/>
                            <field name="divisor_l"/>
                            <field name="coef_h"/>
                            <field name="offset_h"/>
                            <field name="divisor_h"/>
                            <field name="constant"/>
                            <field name="uom_kind"/>
                            <field name="rounding_mode"/>
                            <field name="rule_kind" groups="base.group_no_one"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Famille de formule">
                            <group>
                                <field name="product_is_placeholder" invisible="1"/>
                                <div class="alert alert-warning" invisible="not product_is_placeholder">
                                    L'article lie est un produit temporaire cree automatiquement depuis la reference importee. Vous pouvez le remplacer plus tard par un article definitif.
                                </div>
                                <div class="o_form_label">
                                    Le moteur priorise la famille de formule et ses parametres numeriques. Les expressions libres restent disponibles en compatibilite legacy.
                                </div>
                            </group>
                        </page>
                        <page string="Compatibilite legacy" groups="base.group_no_one">
                            <group>
                                <field name="base_dimension"/>
                                <field name="operator"/>
                                <field name="fixed_offset_mm"/>
                                <field name="divisor"/>
                                <field name="apply_quantity"/>
                                <field name="expression_value"/>
                                <div class="o_form_label">
                                    Utilisez les variables Q, L et H pour la quantite, la largeur et la hauteur.
                                </div>
                            </group>
                        </page>
                        <page string="Remplissage legacy" groups="base.group_no_one">
                            <group>
                                <field name="width_expression"/>
                                <field name="height_expression"/>
                                <field name="qty_expression"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aluminium_joinery_rule" model="ir.actions.act_window">
        <field name="name">Regles</field>
        <field name="res_model">aluminium.joinery.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aluminium_joinery_rule_import" model="ir.actions.act_window">
        <field name="name">Importer les regles</field>
        <field name="res_model">aluminium.joinery.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Utilisez le menu d'action pour importer vos regles.</p>
            <p>Le panneau d'aide de l'import natif contient le modele de regles ainsi que l'exemplaire complet du catalogue VBA.</p>
        </field>
    </record>

    <record id="view_aluminium_joinery_filling_rule_tree" model="ir.ui.view">
        <field name="name">aluminium.joinery.filling.rule.tree</field>
        <field name="model">aluminium.joinery.filling.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="modele_id"/>
                <field name="sequence"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="family_width"/>
                <field name="family_height"/>
                <field name="family_qty"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_aluminium_joinery_filling_rule_form" model="ir.ui.view">
        <field name="name">aluminium.joinery.filling.rule.form</field>
        <field name="model">aluminium.joinery.filling.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="modele_id"/>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="product_id"/>
                            <field name="product_default_code"/>
                            <field name="rule_code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="family_width"/>
                            <field name="width_coef_l"/>
                            <field name="width_coef_h"/>
                            <field name="width_constant"/>
                            <field name="family_height"/>
                            <field name="height_coef_l"/>
                            <field name="height_coef_h"/>
                            <field name="height_constant"/>
                            <field name="family_qty"/>
                            <field name="qty_multiplier"/>
                            <field name="qty_constant"/>
                            <field name="product_is_placeholder" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aluminium_joinery_filling_rule" model="ir.actions.act_window">
        <field name="name">Remplissages</field>
        <field name="res_model">aluminium.joinery.filling.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

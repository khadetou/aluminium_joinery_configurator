<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_aluminium_joinery" model="ir.ui.view">
        <field name="name">product.template.form.aluminium.joinery</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']/group" position="after">
                <group string="Menuiserie aluminium">
                    <group>
                        <field name="joinery_item_type"/>
                        <field name="joinery_usage_role"/>
                        <field name="is_joinery_composite"/>
                        <field name="is_placeholder_product_tmpl"/>
                        <field name="manufacturing_mode"/>
                    </group>
                    <group>
                        <field name="standard_length_mm"/>
                        <field name="joinery_bar_length_mm" groups="base.group_no_one"/>
                        <field name="ajc_default_cut_type" groups="base.group_no_one"/>
                        <field name="ajc_is_configurator_item" groups="base.group_no_one"/>
                        <field name="ajc_item_type" groups="base.group_no_one"/>
                        <field name="ajc_usage_role" groups="base.group_no_one"/>
                        <field name="ajc_bar_length_mm" groups="base.group_no_one"/>
                        <field name="ajc_can_be_sale_component" groups="base.group_no_one"/>
                        <field name="ajc_can_be_mrp_component" groups="base.group_no_one"/>
                        <field name="schuller_item_type" groups="base.group_no_one"/>
                        <field name="schuller_usage_role" groups="base.group_no_one"/>
                        <field name="schuller_bar_length_mm" groups="base.group_no_one"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
